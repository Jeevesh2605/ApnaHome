# Root .gitignore
cat > .gitignore << 'EOF'
# Environment variables
.env
.env.local
.env.production

# Dependencies
node_modules/

# Build output
dist/
build/

# Firebase service account key — NEVER commit this
serviceAccountKey.json
*serviceAccount*.json

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Render / deployment
.render/
